# EpistemicOps Environment Configuration
# Copy this to .env and fill in your values

# LLM Judge API (at least one required)
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# Judge model selection
JUDGE_PROVIDER=openai  # "anthropic" or "openai"
JUDGE_MODEL=gpt-4o-mini  # e.g. "gpt-4o-mini"

# Primary agent model selection (OpenAI)
PRIMARY_AGENT_MODEL=gpt-4o-mini

# HuggingFace (for model push & Spaces)
HF_TOKEN=your-hf-token-here
HF_REPO_ID=your-username/epistemicops

# Training
WANDB_API_KEY=your-wandb-key-here
WANDB_PROJECT=epistemicops

# Mock API URLs (Docker defaults)
INCIDENT_API_URL=http://localhost:8001
METRICS_API_URL=http://localhost:8002
DEPLOY_API_URL=http://localhost:8003
LOG_API_URL=http://localhost:8004
NOTIFY_API_URL=http://localhost:8005
